__pycache__/
*.pyc
.DS_Store

# Local backups of DB (kept on disk only, not in version control)
db/backups/

# Per-user Claude Code settings (permissions allowlist is user-specific)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Build artifacts (regenerated from db/ by skill scripts)
dist/

# Phase 3 paper text cache (regenerated by scripts/phase3/fetch_arxiv_texts.py)
# bibliography YAML is kept in git for curation state; raw paper text is not.
docs/phase3/_papers/

.venv/

# Obsidian auto-generated canvas files (created when user accidentally
# clicks "new canvas"; not part of the wiki layer)
*.canvas

# Obsidian vault overlay: commit only the shared config files
# (app.json, graph.json, appearance.json). Everything else under
# .obsidian/ is per-user state (workspace layout, plugins, cache, hotkeys).
.obsidian/*
!.obsidian/app.json
!.obsidian/graph.json
!.obsidian/appearance.json

# ============================================================
# Mod archives — NEVER commit, NEVER push.
# ============================================================
# blackrack's EVE / Scatterer Early Access bundles are paid Patreon
# content. Re-hosting them (or even tracking them in this public repo)
# would violate his distribution terms and constitute copyright
# infringement. Any EVE/Scatterer cfg/DLL/shader/asset sourced from
# an EA bundle must live OUTSIDE this repo entirely — convention:
# ~/Desktop/ksp-mod-refs/ .
*.zip
*.7z
*.tar.gz
*.rar

# ============================================================
# Scatterer / EVE / Volumetric-Clouds skills — local-only.
# ============================================================
# Decided 2026-05-23: any skill whose schema or behavior is derived
# from blackrack's Patreon Early Access bundle (Scatterer-EA Scatterer.dll,
# EVE V5 Raymarched Volumetrics, etc.) stays entirely local. Even
# "factual" field-schema documentation can leak EA-only knowledge
# that subscribers paid for, so we don't try to slice the line —
# the whole workspace and the eventual live skill never enter git.
# Future eve-cfg / volumetrics-cfg / parallax-cfg-if-EA workspaces
# fall under the same rule.
.agents/skills/scatterer-cfg-workspace/
.agents/skills/scatterer-cfg/
.agents/skills/eve-cfg-workspace/
.agents/skills/eve-cfg/
.agents/skills/volumetrics-cfg-workspace/
.agents/skills/volumetrics-cfg/
.agents/skills/raymarched-*/

# Decided 2026-06-11: the Firefly upstream-contribution brief stays local
# until the user decides to actually send it (outreach draft, not repo doc).
.agents/skills/firefly-cfg-workspace/firefly-contribution-brief.md
.agents/skills/firefly-cfg-workspace/firefly-contribution-brief.ko.md




# Ignore Smart Environment folder
.smart-env/
# stability-sim run logs + checkpoints (regenerated; not curation state)
phase3/stability-sim/run_*.log
phase3/stability-sim/log_*.log
phase3/stability-sim/results/*_ckpt.bin
