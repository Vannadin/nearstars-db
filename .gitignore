__pycache__/
*.pyc
.DS_Store

# Local backups of DB (kept on disk only, not in version control)
db/backups/

# Per-user Claude Code settings (permissions allowlist is user-specific)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Build artifacts (regenerated from db/ by skill scripts)
dist/

# Phase 3 paper text cache (regenerated by scripts/phase3/fetch_arxiv_texts.py)
# bibliography YAML is kept in git for curation state; raw paper text is not.
docs/phase3/_papers/

.venv/

# Obsidian vault overlay: commit only the shared config files
# (app.json, graph.json, appearance.json). Everything else under
# .obsidian/ is per-user state (workspace layout, plugins, cache, hotkeys).
.obsidian/*
!.obsidian/app.json
!.obsidian/graph.json
!.obsidian/appearance.json




# Ignore Smart Environment folder
.smart-env